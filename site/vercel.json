{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/__rewrite-test/",       "destination": "/about-us.html" },
    { "source": "/blog/:slug",            "destination": "/blog-:slug.html" },
    { "source": "/blog/:slug/",           "destination": "/blog-:slug.html" },
    { "source": "/case-study/:slug",      "destination": "/case-study-:slug.html" },
    { "source": "/case-study/:slug/",     "destination": "/case-study-:slug.html" }
  ],
  "redirects": [
    { "source": "/blog-:slug/",           "destination": "/blog/:slug/",       "permanent": true },
    { "source": "/case-study-:slug/",     "destination": "/case-study/:slug/", "permanent": true }
  ]
}
